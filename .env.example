DATABASE_URL="postgresql://postgres:password@localhost:5432/gpssa_compass?schema=public"
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI (required only when running research agents)
OPENAI_API_KEY=""

# Seed credentials — set these before any customer / Railway deploy.
# Defaults in seed.ts are change-me-* and will WARN if unset.
SEED_ADMIN_EMAIL="utena.treves@gmail.com"
SEED_ADMIN_PASSWORD="rotate-this-admin-password"
SEED_ADMIN_NAME="Platform Admin"
SEED_DEMO_PASSWORD="rotate-this-demo-password"

# Password for the login-form counter screen (no dashboard session).
# Enter this on the demo access form to see how often the standard password was used.
LOGIN_STATS_PASSWORD="HowMany"

# Optional project-team editor (can mutate ops data; cannot run research agents)
SEED_EDITOR_EMAIL=""
SEED_EDITOR_PASSWORD=""
SEED_EDITOR_NAME="Project Editor"
