generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  role                String   @default("user")
  userType            String   @default("gpssa")
  department          String?
  avatar              String?
  hasCompletedProfile Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AppConfig {
  key   String @id
  value String
}

model AgentConfig {
  id                 String           @id @default(cuid())
  name               String           @unique
  description        String?
  systemPrompt       String
  userPromptTemplate String
  model              String           @default("gpt-4o")
  provider           String           @default("openai")
  maxTokens          Int              @default(4096)
  temperature        Float            @default(0.7)
  concurrency        Int              @default(5)
  batchSize          Int              @default(1)
  isActive           Boolean          @default(true)
  targetScreen       String?
  researchType       String?
  sortOrder          Int              @default(0)
  executionCount     Int              @default(0)
  lastRunAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  executions         AgentExecution[]
  researchJobs       ResearchJob[]
}

model AgentExecution {
  id         String      @id @default(cuid())
  agentId    String
  agent      AgentConfig @relation(fields: [agentId], references: [id])
  input      String
  output     String?
  model      String
  tokensUsed Int?
  durationMs Int?
  status     String      @default("running")
  error      String?
  createdAt  DateTime    @default(now())

  @@index([agentId])
}

model Country {
  id                          String                  @id @default(cuid())
  iso3                        String                  @unique
  iso2                        String?
  name                        String                  @unique
  flag                        String?
  region                      String
  subRegion                   String?
  peerGroup                   String?
  incomeGroup                 String?
  institution                 String?
  systemType                  String?
  yearEstablished             Int?
  maturityScore               Float?
  maturityLabel               String?
  coverageRate                Float?
  replacementRate             Float?
  sustainability              Float?
  digitalLevel                String?
  keyFeatures                 String?
  challenges                  String?
  insights                    String?
  legislativeFramework        String?
  contributionRates           String?
  retirementAge               String?
  benefitTypes                String?
  fundManagement              String?
  recentReforms               String?
  internationalRankings       String?
  iloConventionsRatified      String?
  populationCovered           String?
  dataSources                 String?
  socialProtectionExpenditure String?
  dependencyRatio             String?
  pensionFundAssets           String?
  benefitCalculation          String?
  indexationMechanism         String?
  vestingPeriod               String?
  governanceQuality           String?
  researchStatus              String                  @default("pending")
  systemStatus                String                  @default("pending")
  performanceStatus           String                  @default("pending")
  insightsStatus              String                  @default("pending")
  researchedAt                DateTime?
  researchSource              String?
  rawResearchData             String?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  institutions                Institution[]
  sourceCitations             CountrySourceCitation[]

  @@index([region])
  @@index([researchStatus])
}

model OrchestratorRun {
  id          String    @id @default(cuid())
  status      String    @default("pending")
  pillars     String?
  results     String?
  lastError   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([startedAt])
}

model ResearchJob {
  id             String            @id @default(cuid())
  type           String            @default("country-research")
  status         String            @default("pending")
  totalItems     Int               @default(0)
  completedItems Int               @default(0)
  failedItems    Int               @default(0)
  currentItem    String?
  model          String            @default("gpt-4o")
  batchSize      Int               @default(3)
  concurrency    Int               @default(5)
  totalTokens    Int               @default(0)
  totalCost      Float             @default(0)
  agentConfigId  String?
  agentConfig    AgentConfig?      @relation(fields: [agentConfigId], references: [id])
  rawOutput      String?
  startedAt      DateTime?
  completedAt    DateTime?
  pausedAt       DateTime?
  lastError      String?
  errorCount     Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  items          ResearchJobItem[]

  @@index([agentConfigId])
  @@index([type])
}

model ResearchJobItem {
  id          String      @id @default(cuid())
  jobId       String
  job         ResearchJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  countryIso3 String?
  itemKey     String?
  itemLabel   String?
  itemContext String?
  status      String      @default("pending")
  tokensUsed  Int         @default(0)
  durationMs  Int         @default(0)
  output      String?
  error       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([jobId])
  @@index([itemKey])
}

model ScoringMethodology {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  weights     ScoringWeight[]
}

model ScoringWeight {
  id            String             @id @default(cuid())
  methodologyId String
  methodology   ScoringMethodology @relation(fields: [methodologyId], references: [id], onDelete: Cascade)
  dimension     String
  weight        Float              @default(1.0)
  maxScore      Float              @default(100)
  description   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([methodologyId, dimension])
  @@index([methodologyId])
}

model Institution {
  id                    String                         @id @default(cuid())
  name                  String                         @unique
  shortName             String?
  country               String
  countryCode           String
  region                String
  countryId             String?
  countryRef            Country?                       @relation(fields: [countryId], references: [id])
  isBenchmarkTarget     Boolean                        @default(false)
  description           String?
  services              String?
  digitalMaturity       String?
  keyInnovations        String?
  aiAnalysis            String?
  websiteUrl            String?
  strengths             String?
  gaps                  String?
  transferablePractices String?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  benchmarksAs          BenchmarkReport[]              @relation("BenchmarkTarget")
  benchmarksOf          BenchmarkReport[]              @relation("BenchmarkComparison")
  benchmarkDatasets     BenchmarkDataset[]             @relation("BenchmarkTargetInstitution")
  benchmarkScores       BenchmarkInstitutionScore[]
  sourceCitations       InstitutionSourceCitation[]
  internationalServices InternationalService[]
  internationalProducts InternationalProduct[]
  internationalChannels InternationalDeliveryChannel[]

  @@index([countryCode])
  @@index([countryId])
}

model BenchmarkDataset {
  id                  String                      @id @default(cuid())
  slug                String                      @unique
  name                String
  description         String?
  methodology         String?
  coverageNote        String?
  targetInstitutionId String?
  targetInstitution   Institution?                @relation("BenchmarkTargetInstitution", fields: [targetInstitutionId], references: [id])
  publishedAt         DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  scores              BenchmarkInstitutionScore[]
  kpiValues           BenchmarkKpiValue[]
}

model BenchmarkDimension {
  id          String                      @id @default(cuid())
  slug        String                      @unique
  name        String
  description String?
  category    String?
  sortOrder   Int                         @default(0)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  scores      BenchmarkInstitutionScore[]
}

model BenchmarkSource {
  id          String                            @id @default(cuid())
  slug        String                            @unique
  title       String
  publisher   String?
  url         String
  sourceType  String                            @default("website")
  description String?
  region      String?
  publishedAt DateTime?
  accessedAt  DateTime?
  notes       String?
  createdAt   DateTime                          @default(now())
  updatedAt   DateTime                          @updatedAt
  scoreLinks  BenchmarkInstitutionScoreSource[]
  kpiLinks    BenchmarkKpiValueSource[]
}

model BenchmarkInstitutionScore {
  id            String                            @id @default(cuid())
  datasetId     String
  institutionId String
  dimensionId   String
  score         Float
  maturityLabel String?
  note          String?
  createdAt     DateTime                          @default(now())
  updatedAt     DateTime                          @updatedAt
  dataset       BenchmarkDataset                  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  institution   Institution                       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  dimension     BenchmarkDimension                @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  sourceLinks   BenchmarkInstitutionScoreSource[]

  @@unique([datasetId, institutionId, dimensionId])
  @@index([institutionId])
  @@index([dimensionId])
}

model BenchmarkInstitutionScoreSource {
  id           String                    @id @default(cuid())
  scoreId      String
  sourceId     String
  citation     String?
  evidenceNote String?
  sortOrder    Int                       @default(0)
  createdAt    DateTime                  @default(now())
  score        BenchmarkInstitutionScore @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  source       BenchmarkSource           @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([scoreId, sourceId])
  @@index([sourceId])
}

model BenchmarkKpi {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?
  category    String?
  unit        String?
  direction   String              @default("higher-better")
  ribbonLabel String?
  ribbonOrder Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  values      BenchmarkKpiValue[]
}

model BenchmarkKpiValue {
  id          String                    @id @default(cuid())
  datasetId   String
  kpiId       String
  comparator  String
  label       String
  value       Float
  note        String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  dataset     BenchmarkDataset          @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  kpi         BenchmarkKpi              @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  sourceLinks BenchmarkKpiValueSource[]

  @@unique([datasetId, kpiId, comparator])
  @@index([kpiId])
}

model BenchmarkKpiValueSource {
  id           String            @id @default(cuid())
  valueId      String
  sourceId     String
  citation     String?
  evidenceNote String?
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  value        BenchmarkKpiValue @relation(fields: [valueId], references: [id], onDelete: Cascade)
  source       BenchmarkSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([valueId, sourceId])
  @@index([sourceId])
}

model BenchmarkReport {
  id           String      @id @default(cuid())
  targetId     String
  target       Institution @relation("BenchmarkTarget", fields: [targetId], references: [id])
  comparisonId String
  comparison   Institution @relation("BenchmarkComparison", fields: [comparisonId], references: [id])
  analysis     String
  createdAt    DateTime    @default(now())

  @@index([targetId])
}

model GPSSAService {
  id                     String                     @id @default(cuid())
  name                   String
  category               String
  description            String?
  userTypes              String?
  currentState           String?
  painPoints             String?
  opportunities          String?
  digitalReadiness       Float?
  maturityLevel          String?
  bestPracticeComparison String?
  strengths              String?
  iloAlignment           String?
  researchStatus         String                     @default("pending")
  researchSource         String?
  analyses               ServiceAnalysis[]
  channelCapabilities    ServiceChannelCapability[]
  sourceCitations        ServiceSourceCitation[]
  // Service Operating Spine (RFP leave-behind ops chain)
  episodes               CustomerEpisode[]
  journeyStages          JourneyStage[]
  operatingProcesses     OperatingProcess[]
  qaScorecards           QAScorecard[]
  slaDefinitions         SLADefinition[]
  serviceCases           ServiceCase[]
  defects                Defect[]
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
}

model ServiceAnalysis {
  id        String       @id @default(cuid())
  serviceId String
  service   GPSSAService @relation(fields: [serviceId], references: [id])
  analysis  String
  model     String?
  createdAt DateTime     @default(now())

  @@index([serviceId])
}

model Opportunity {
  id                String                      @id @default(cuid())
  title             String
  category          String
  description       String?
  impact            String                      @default("medium")
  effort            String                      @default("medium")
  strategicFit      Float?
  feasibility       Float?
  status            String                      @default("identified")
  sourceSection     String?
  // Soft PMO workflow (engagement working file).
  owner             String?
  decisionLoggedAt  DateTime?
  workshopNotes     String?
  // Workstream B: explicit prioritisation scoring (RICE / WSJF).
  riceScore         Float?
  wsjfScore         Float?
  conceptSheet      ConceptSheet?
  sourceCitations   OpportunitySourceCitation[]
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
}

/// Lightweight workshop / pilot captures (services, pilot set, free notes).
model EngagementCapture {
  id         String   @id @default(cuid())
  entityType String // service | pilot-set | general
  entityId   String?
  body       String
  author     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType, entityId])
}

model ConceptSheet {
  id            String      @id @default(cuid())
  opportunityId String      @unique
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  content       String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Requirement {
  id              String                      @id @default(cuid())
  category        String
  title           String
  description     String?
  details         String?
  priority        String                      @default("medium")
  status          String                      @default("identified")
  sourceCitations RequirementSourceCitation[]
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
}

model RoadmapPhase {
  id          String              @id @default(cuid())
  name        String
  description String?
  workstream  String? // A (Product & Service Roadmap) | B (QA Framework) — RFP §2.3
  startDate   String?
  endDate     String?
  objectives  String?
  sortOrder   Int                 @default(0)
  initiatives RoadmapInitiative[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model RoadmapInitiative {
  id              String       @id @default(cuid())
  phaseId         String
  phase           RoadmapPhase @relation(fields: [phaseId], references: [id])
  title           String
  description     String?
  status          String       @default("planned")
  owner           String?
  dependencies    String?
  estimatedImpact String?
  sortOrder       Int          @default(0)
  benefits        BenefitsRealisation[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([phaseId])
}

model Risk {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String?
  probability String   @default("medium")
  impact      String   @default("medium")
  mitigation  String?
  owner       String?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KPI {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  target      String?
  actual      String?
  unit        String?
  frequency   String   @default("monthly")
  owner       String?
  pillar      String?
  // Workstream B: KPI vs KQI catalogue (TM Forum GB917 + Balanced Scorecard).
  kind        String   @default("kpi") // kpi | kqi
  timing      String? // leading | lagging
  perspective String? // financial | customer | process | capacity
  tier        String? // operational | tactical | strategic
  direction   String   @default("higher-better") // higher-better | lower-better
  parentId    String? // KQI -> feeding-KPI decomposition
  parent      KPI?     @relation("KpiDecomposition", fields: [parentId], references: [id], onDelete: SetNull)
  children    KPI[]    @relation("KpiDecomposition")
  measurements KpiMeasurement[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
}

model Activity {
  id        String   @id @default(cuid())
  actor     String
  action    String
  details   String?
  createdAt DateTime @default(now())
}

// ── Universal Data Source & Citation Models ──

model DataSource {
  id          String    @id @default(cuid())
  title       String
  url         String
  publisher   String?
  sourceType  String    @default("website")
  description String?
  region      String?
  publishedAt DateTime?
  accessedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  serviceCitations           ServiceSourceCitation[]
  institutionCitations       InstitutionSourceCitation[]
  opportunityCitations       OpportunitySourceCitation[]
  requirementCitations       RequirementSourceCitation[]
  productCitations           ProductSourceCitation[]
  segmentCitations           SegmentSourceCitation[]
  innovationCitations        InnovationSourceCitation[]
  channelCitations           ChannelSourceCitation[]
  personaCitations           PersonaSourceCitation[]
  deliveryModelCitations     DeliveryModelSourceCitation[]
  intlServiceCitations       IntlServiceCitation[]
  intlProductCitations       IntlProductCitation[]
  intlSegmentCitations       IntlSegmentCitation[]
  intlChannelCitations       IntlChannelCitation[]
  intlPersonaCitations       IntlPersonaCitation[]
  intlDeliveryModelCitations IntlDeliveryModelCitation[]
  countryCitations           CountrySourceCitation[]
  standardCitations          StandardSourceCitation[]
  complianceCitations        StandardComplianceSourceCitation[]
  qaScorecardCitations       QAScorecardSourceCitation[]
}

model CountrySourceCitation {
  id           String     @id @default(cuid())
  countryId    String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime   @default(now())
  country      Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)
  source       DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([countryId, sourceId])
  @@index([sourceId])
}

model ServiceSourceCitation {
  id           String       @id @default(cuid())
  serviceId    String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime     @default(now())
  service      GPSSAService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  source       DataSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, sourceId])
  @@index([sourceId])
}

model InstitutionSourceCitation {
  id            String      @id @default(cuid())
  institutionId String
  sourceId      String
  citation      String?
  evidenceNote  String?
  createdAt     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  source        DataSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([institutionId, sourceId])
  @@index([sourceId])
}

model OpportunitySourceCitation {
  id            String      @id @default(cuid())
  opportunityId String
  sourceId      String
  citation      String?
  evidenceNote  String?
  createdAt     DateTime    @default(now())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  source        DataSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, sourceId])
  @@index([sourceId])
}

model RequirementSourceCitation {
  id            String      @id @default(cuid())
  requirementId String
  sourceId      String
  citation      String?
  evidenceNote  String?
  createdAt     DateTime    @default(now())
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  source        DataSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([requirementId, sourceId])
  @@index([sourceId])
}

// ── Screen Research Domain Models ──

model Product {
  id                      String                  @id @default(cuid())
  name                    String
  tier                    String
  status                  String                  @default("active")
  description             String?
  targetSegments          String?
  coverageType            String?
  keyFeatures             String?
  regulatoryBasis         String?
  comparableInternational String?
  researchStatus          String                  @default("pending")
  researchSource          String?
  sourceCitations         ProductSourceCitation[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([tier])
}

model SegmentCoverage {
  id              String                  @id @default(cuid())
  segment         String
  coverageType    String
  level           String
  population      String?
  notes           String?
  regulatoryBasis String?
  researchStatus  String                  @default("pending")
  researchSource  String?
  sourceCitations SegmentSourceCitation[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([segment, coverageType])
}

model ProductInnovation {
  id                  String                     @id @default(cuid())
  title               String
  description         String?
  targetSegment       String?
  impactScore         Float?
  feasibilityScore    Float?
  status              String                     @default("identified")
  innovationType      String?
  estimatedPopulation String?
  researchStatus      String                     @default("pending")
  researchSource      String?
  sourceCitations     InnovationSourceCitation[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
}

model DeliveryChannel {
  id                  String                  @id @default(cuid())
  name                String                  @unique
  channelType         String
  maturity            Float                   @default(0)
  servicesAvailable   Int                     @default(0)
  servicesTotal       Int                     @default(0)
  status              String                  @default("active")
  capabilities        String?
  strengths           String?
  gaps                String?
  benchmarkComparison String?
  researchStatus      String                  @default("pending")
  researchSource      String?
  sourceCitations     ChannelSourceCitation[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
}

model CustomerPersona {
  id                String                  @id @default(cuid())
  name              String                  @unique
  headline          String?
  ageRange          String?
  city              String?
  occupation        String?
  incomeRange       String?
  description       String?
  needs             String?
  coverageMap       String?
  segment           String?
  journeyHighlights String?
  channelPreference String?
  researchStatus    String                  @default("pending")
  researchSource    String?
  sourceCitations   PersonaSourceCitation[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

model DeliveryModel {
  id                String                        @id @default(cuid())
  name              String                        @unique
  description       String?
  channelMix        String?
  targetSegments    String?
  maturity          Float                         @default(0)
  enablers          String?
  risks             String?
  benchmarkExamples String?
  researchStatus    String                        @default("pending")
  researchSource    String?
  sourceCitations   DeliveryModelSourceCitation[]
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
}

model ServiceChannelCapability {
  id              String       @id @default(cuid())
  serviceId       String
  service         GPSSAService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  channelName     String
  capabilityLevel String       @default("None")
  notes           String?
  researchStatus  String       @default("pending")
  researchSource  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([serviceId, channelName])
  @@index([serviceId])
}

// ── Citation Join Tables for New Models ──

model ProductSourceCitation {
  id           String     @id @default(cuid())
  productId    String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime   @default(now())
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  source       DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([productId, sourceId])
  @@index([sourceId])
}

model SegmentSourceCitation {
  id           String          @id @default(cuid())
  segmentId    String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime        @default(now())
  segment      SegmentCoverage @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  source       DataSource      @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([segmentId, sourceId])
  @@index([sourceId])
}

model InnovationSourceCitation {
  id           String            @id @default(cuid())
  innovationId String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime          @default(now())
  innovation   ProductInnovation @relation(fields: [innovationId], references: [id], onDelete: Cascade)
  source       DataSource        @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([innovationId, sourceId])
  @@index([sourceId])
}

model ChannelSourceCitation {
  id           String          @id @default(cuid())
  channelId    String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime        @default(now())
  channel      DeliveryChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  source       DataSource      @relation(fields: [sourceId], references: [id], onDelete: Cascade)

