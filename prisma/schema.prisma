  researchStatus    String                      @default("pending")
  researchSource    String?
  sourceCitations   IntlDeliveryModelCitation[]
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@unique([countryIso3, name])
  @@index([countryIso3])
}

model IntlChannelCitation {
  id           String                       @id @default(cuid())
  channelId    String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime                     @default(now())
  channel      InternationalDeliveryChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  source       DataSource                   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([channelId, sourceId])
  @@index([sourceId])
}

model IntlPersonaCitation {
  id           String                       @id @default(cuid())
  personaId    String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime                     @default(now())
  persona      InternationalCustomerPersona @relation(fields: [personaId], references: [id], onDelete: Cascade)
  source       DataSource                   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([personaId, sourceId])
  @@index([sourceId])
}

model IntlDeliveryModelCitation {
  id              String                     @id @default(cuid())
  deliveryModelId String
  sourceId        String
  citation        String?
  evidenceNote    String?
  createdAt       DateTime                   @default(now())
  deliveryModel   InternationalDeliveryModel @relation(fields: [deliveryModelId], references: [id], onDelete: Cascade)
  source          DataSource                 @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([deliveryModelId, sourceId])
  @@index([sourceId])
}

// ── Canonical Standards Library ──
//
// A `Standard` represents a globally accepted reference (ILO Convention,
// ISSA Guideline, World Bank framework, OECD index, UN survey, etc.).
// Each standard has a list of `StandardRequirement`s — concrete, verifiable
// criteria that an entity (institution / service / product / channel / country)
// can be scored against. Per-entity scores are stored in `StandardCompliance`,
// with citations into the existing DataSource library.

model Standard {
  id           String                   @id @default(cuid())
  slug         String                   @unique
  code         String?
  title        String
  body         String
  bodyShort    String?
  category     String
  scope        String                   @default("global")
  region       String?
  description  String?
  rationale    String?
  url          String?
  publishedAt  DateTime?
  isActive     Boolean                  @default(true)
  sortOrder    Int                      @default(0)
  metadata     String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  requirements StandardRequirement[]
  compliances  StandardCompliance[]
  sourceLinks  StandardSourceCitation[]

  @@index([category])
  @@index([body])
}

model StandardRequirement {
  id          String                   @id @default(cuid())
  standardId  String
  standard    Standard                 @relation(fields: [standardId], references: [id], onDelete: Cascade)
  slug        String
  code        String?
  title       String
  description String?
  weight      Float                    @default(1.0)
  pillar      String?
  sortOrder   Int                      @default(0)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  scores      StandardComplianceItem[]

  @@unique([standardId, slug])
  @@index([standardId])
}

model StandardCompliance {
  id          String                             @id @default(cuid())
  standardId  String
  standard    Standard                           @relation(fields: [standardId], references: [id], onDelete: Cascade)
  entityType  String
  entityId    String
  entityLabel String?
  countryIso3 String?
  score       Float
  band        String?
  rationale   String?
  computedBy  String                             @default("agent")
  asOfDate    DateTime?
  metadata    String?
  itemScores  StandardComplianceItem[]
  sourceLinks StandardComplianceSourceCitation[]
  createdAt   DateTime                           @default(now())
  updatedAt   DateTime                           @updatedAt

  @@unique([standardId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([countryIso3])
}

model StandardComplianceItem {
  id            String              @id @default(cuid())
  complianceId  String
  compliance    StandardCompliance  @relation(fields: [complianceId], references: [id], onDelete: Cascade)
  requirementId String
  requirement   StandardRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  score         Float
  status        String              @default("partial")
  evidence      String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([complianceId, requirementId])
  @@index([requirementId])
}

model StandardSourceCitation {
  id           String     @id @default(cuid())
  standardId   String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime   @default(now())
  standard     Standard   @relation(fields: [standardId], references: [id], onDelete: Cascade)
  source       DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([standardId, sourceId])
  @@index([sourceId])
}

model StandardComplianceSourceCitation {
  id           String             @id @default(cuid())
  complianceId String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime           @default(now())
  compliance   StandardCompliance @relation(fields: [complianceId], references: [id], onDelete: Cascade)
  source       DataSource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([complianceId, sourceId])
  @@index([sourceId])
}

// ── Computed References (Global / Regional / Peer averages & best-practice) ──
//
// Materialized aggregate values derived deterministically from existing
// international data (Country, InternationalService, BenchmarkInstitutionScore, …).
// Refreshed by a periodic job and on-demand. They are first-class comparators
// in the UI alongside Standards and individual Countries.

model ComputedReference {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  shortName   String?
  kind        String
  scope       String
  description String?
  formula     String?
  asOfDate    DateTime?
  cohortSize  Int       @default(0)
  payload     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([kind])
  @@index([scope])
}

// ── GPSSA Mandate Corpus ──
//
// Net-new tables backing the MANDATE pillar. The legal/regulatory content
// itself is stored as Standard / StandardRequirement rows (re-using the
// existing Standards machinery), with citations through DataSource. These
// two models hold the editorial substrate the agent ingests + the human
// timeline used by the History view.

model GpssaPage {
  id           String   @id @default(cuid())
  slug         String   @unique
  url          String   @unique
  lang         String   @default("en")
  title        String
  section      String?
  contentType  String   @default("html")
  htmlSnapshot String?
  markdown     String
  etag         String?
  lastModified String?
  pdfPath      String?
  scrapedAt    DateTime @default(now())
  hash         String

  @@index([section])
}

model GpssaMilestone {
  id          String   @id @default(cuid())
  year        Int
  date        String?
  title       String
  description String
  kind        String   @default("milestone")
  sourceUrl   String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([year])
}

// ════════════════════════════════════════════════════════════════════════
// WORKSTREAM B — End-to-End Quality Assurance & Service Fulfilment Framework
// (RFP #GPSSA-016-2026). Anchored to COPC (3-metric quality), ISO/Six Sigma,
// ITIL SLA/OLA, Balanced Scorecard, ISSA service-quality guidelines.
// ════════════════════════════════════════════════════════════════════════

// ── MG1: Quality Assurance Framework ──

model QualityDimension {
  id          String   @id @default(cuid())
  name        String
  definition  String?
  category    String   @default("accuracy") // accuracy | completeness | compliance | timeliness | cx | consistency
  copcFamily  String? // customer | business | compliance
  weight      Float    @default(1.0)
  sortOrder   Int      @default(0)
  criteria    QAScorecardCriterion[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QAScorecard {
  id              String                      @id @default(cuid())
  name            String
  description     String?
  serviceScope    String? // legacy free-text; prefer serviceId
  serviceId       String?
  service         GPSSAService?               @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  status          String                      @default("draft") // draft | active | archived
  criteria        QAScorecardCriterion[]
  samplingPlans   QASamplingPlan[]
  reviews         QAReview[]
  calibrations    QACalibrationSession[]
  sourceCitations QAScorecardSourceCitation[]
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@index([serviceId])
}

model QAScorecardCriterion {
  id          String           @id @default(cuid())
  scorecardId String
  scorecard   QAScorecard      @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  dimensionId String?
  dimension   QualityDimension? @relation(fields: [dimensionId], references: [id], onDelete: SetNull)
  text        String
  weight      Float            @default(1.0)
  critical    Boolean          @default(false) // auto-fail criterion
  sortOrder   Int              @default(0)
  reviewItems QAReviewItem[]
  createdAt   DateTime         @default(now())

  @@index([scorecardId])
}

model QASamplingPlan {
  id              String      @id @default(cuid())
  scorecardId     String
  scorecard       QAScorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  method          String      @default("hybrid") // statistical | risk-based | hybrid
  populationSize  Int         @default(0)
  confidenceLevel Float       @default(95)
  marginError     Float       @default(5)
  sampleSize      Int         @default(0)
  riskWeighting   String?
  cadence         String      @default("monthly")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([scorecardId])
}

model QAReview {
  id                String         @id @default(cuid())
  scorecardId       String
  scorecard         QAScorecard    @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  serviceName       String?
  caseRef           String
  caseId            String?
  case              ServiceCase?   @relation(fields: [caseId], references: [id], onDelete: SetNull)
  reviewer          String?
  totalScore        Float          @default(0)
  customerAccuracy  Boolean        @default(true) // COPC: free of customer-critical error
  businessAccuracy  Boolean        @default(true) // COPC: free of business-critical error
  complianceAccuracy Boolean       @default(true) // COPC: free of compliance-critical error
  autoFailTriggered Boolean        @default(false)
  status            String         @default("completed") // draft | completed
  reviewedAt        DateTime       @default(now())
  items             QAReviewItem[]
  createdAt         DateTime       @default(now())

  @@index([scorecardId])
  @@index([caseId])
}

model QAReviewItem {
  id          String               @id @default(cuid())
  reviewId    String
  review      QAReview             @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  criterionId String
  criterion   QAScorecardCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  passed      Boolean              @default(true)
  score       Float                @default(0)
  note        String?

  @@index([reviewId])
}

model QACalibrationSession {
  id             String                @id @default(cuid())
  scorecardId    String
  scorecard      QAScorecard           @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  caseRef        String
  sessionDate    DateTime              @default(now())
  evaluatorCount Int                   @default(0)
  irrScore       Float                 @default(0) // inter-rater reliability %
  driftNote      String?
  status         String                @default("completed")
  scores         QACalibrationScore[]
  createdAt      DateTime              @default(now())

  @@index([scorecardId])
}

model QACalibrationScore {
  id        String               @id @default(cuid())
  sessionId String
  session   QACalibrationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  evaluator String
  score     Float                @default(0)

  @@index([sessionId])
}

model ErrorTaxonomyNode {
  id          String              @id @default(cuid())
  parentId    String?
  parent      ErrorTaxonomyNode?  @relation("Taxonomy", fields: [parentId], references: [id], onDelete: SetNull)
  children    ErrorTaxonomyNode[] @relation("Taxonomy")
  code        String              @unique
  name        String
  severity    String              @default("major") // critical | major | minor
  category    String?
  description String?
  sortOrder   Int                 @default(0)
  defects     Defect[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([parentId])
}

model Defect {
  id               String             @id @default(cuid())
  taxonomyNodeId   String?
  taxonomyNode     ErrorTaxonomyNode? @relation(fields: [taxonomyNodeId], references: [id], onDelete: SetNull)
  source           String             @default("qa") // qa | fulfilment
  serviceName      String?
  serviceId        String?
  service          GPSSAService?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  caseRef          String?
  severity         String             @default("major")
  detectedAt       DateTime           @default(now())
  status           String             @default("open") // open | analysing | resolved
  correctiveActions CorrectiveAction[]
  breaches         Breach[]
  createdAt        DateTime           @default(now())

  @@index([taxonomyNodeId])
  @@index([serviceId])
}

model CorrectiveAction {
  id                 String   @id @default(cuid())
  defectId           String?
  defect             Defect?  @relation(fields: [defectId], references: [id], onDelete: SetNull)
  clusterLabel       String?
  title              String
  rootCauseMethod    String   @default("5why") // 5why | fishbone | fault-tree
  rootCause          String?
  actionType         String   @default("corrective") // corrective | preventive
  owner              String?
  dueDate            String?
  status             String   @default("open") // open | in-progress | verified | closed
  effectivenessCheck String?
  cycle              String   @default("pdca") // pdca | dmaic
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([defectId])
}

model QAScorecardSourceCitation {
  id           String      @id @default(cuid())
  scorecardId  String
  sourceId     String
  citation     String?
  evidenceNote String?
  createdAt    DateTime    @default(now())
  scorecard    QAScorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  source       DataSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([scorecardId, sourceId])
  @@index([sourceId])
}

// ── MG2: Service Fulfilment & Breach Reduction ──

model SLADefinition {
  id             String          @id @default(cuid())
  serviceName    String?
  serviceId      String?
  service        GPSSAService?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  name           String
  tier           String          @default("standard") // bronze | silver | gold | standard
  type           String          @default("sla") // sla | ola
  targetHours    Int             @default(24)
  underpinsSlaId String?
  underpins      SLADefinition?  @relation("OlaUnderpins", fields: [underpinsSlaId], references: [id], onDelete: SetNull)
  underpinnedBy  SLADefinition[] @relation("OlaUnderpins")
  direction      String?
  description    String?
  cases          ServiceCase[]
  breaches       Breach[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([serviceId])
}

model ServiceCase {
  id              String         @id @default(cuid())
  serviceName     String?
  serviceId       String?
  service         GPSSAService?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  caseRef         String         @unique
  segment         String         @default("manual-review") // straight-through | manual-review | specialist
  impact          String         @default("medium") // low | medium | high
  urgency         String         @default("medium") // low | medium | high
  priority        String         @default("P3") // P1..P5
  status          String         @default("open") // open | in-progress | on-hold | resolved
  owner           String?
  openedAt        DateTime       @default(now())
  slaId           String?
  sla             SLADefinition? @relation(fields: [slaId], references: [id], onDelete: SetNull)
  dueAt           DateTime?
  resolvedAt      DateTime?
  breached        Boolean        @default(false)
  breachRiskLevel String         @default("green") // green | amber | red
  breaches        Breach[]
  qaReviews       QAReview[]
  createdAt       DateTime       @default(now())

  @@index([slaId])
  @@index([serviceId])
}

model Breach {
  id             String         @id @default(cuid())
  caseId         String?
  case           ServiceCase?   @relation(fields: [caseId], references: [id], onDelete: SetNull)
  slaId          String?
  sla            SLADefinition? @relation(fields: [slaId], references: [id], onDelete: SetNull)
  breachedAt     DateTime       @default(now())
  hoursOver      Int            @default(0)
  reason         String?
  escalationType String         @default("functional") // functional | hierarchical
  defectId       String?
  defect         Defect?        @relation(fields: [defectId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())

  @@index([caseId])
}

model FulfilmentSnapshot {
  id               String   @id @default(cuid())
  serviceName      String?
  period           String
  avgTatHours      Float    @default(0)
  firstTimeRightPct Float   @default(0)
  reworkPct        Float    @default(0)
  backlogCount     Int      @default(0)
  wipOver30        Int      @default(0)
  pcePct           Float    @default(0)
  dpmo             Float    @default(0)
  createdAt        DateTime @default(now())

  @@unique([serviceName, period])
}

// ── MG3: Performance & Voice of Customer ──

model KpiMeasurement {
  id         String   @id @default(cuid())
  kpiId      String
  kpi        KPI      @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  period     String
  value      Float
  target     Float?
  comparator String   @default("GPSSA")
  createdAt  DateTime @default(now())

  @@unique([kpiId, period, comparator])
  @@index([kpiId])
}

model CxMeasurement {
  id          String   @id @default(cuid())
  metric      String // csat | dsat | nps | ces | pulse | fcr | repeat-contact
  serviceName String?
  channel     String?
  period      String
  value       Float
  sampleSize  Int?
  driver      String?
  createdAt   DateTime @default(now())

  @@index([metric])
}

model ComplaintTheme {
  id          String   @id @default(cuid())
  theme       String
  period      String
  count       Int      @default(0)
  sentiment   String   @default("negative")
  serviceName String?
  createdAt   DateTime @default(now())
}

model ComputedKqi {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  kind      String   @default("avg") // avg | best-practice | median | p95
  scope     String   @default("global")
  value     Float    @default(0)
  unit      String?
  formula   String?
  asOfDate  DateTime?
  payload   String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── MG4: Benefits Realisation ──

model BenefitsRealisation {
  id           String             @id @default(cuid())
  initiativeId String?
  initiative   RoadmapInitiative? @relation(fields: [initiativeId], references: [id], onDelete: SetNull)
  title        String
  metric       String
  baseline     Float
  target       Float
  actual       Float?
  unit         String?
  status       String             @default("on-track") // on-track | at-risk | realised | missed
  validatedBy  String?
  validatedAt  String?
  note         String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([initiativeId])
}

// ── MG5: Governance & Operating Model ──

model GovernanceForum {
  id        String   @id @default(cuid())
  name      String
  tier      Int      @default(1) // 1..4
  cadence   String   @default("daily") // daily | weekly | monthly | quarterly
  purpose   String?
  attendees String?
  owner     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RaciEntry {
  id          String   @id @default(cuid())
  processArea String
  activity    String
  team        String
  role        String   @default("R") // R | A | S | C | I
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([processArea])
}

model CapabilityTransferItem {
  id                String   @id @default(cuid())
  phase             String?
  item              String
  mechanism         String   @default("train-the-trainer") // train-the-trainer | playbook | coaching | sustainment-metric
  owner             String?
  status            String   @default("planned") // planned | in-progress | embedded
  sustainmentMetric String?
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ── Service Operating Spine (episode → journey → SOP → systems → QA) ──

model CustomerEpisode {
  id          String         @id @default(cuid())
  serviceId   String
  service     GPSSAService   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int            @default(0)
  stages      JourneyStage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([serviceId])
}

model JourneyStage {
  id          String             @id @default(cuid())
  serviceId   String
  service     GPSSAService       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  episodeId   String?
  episode     CustomerEpisode?   @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  name        String
  actor       String             @default("agent") // customer | agent | system
  outcome     String?
  sortOrder   Int                @default(0)
  processLinks StageProcessLink[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([serviceId])
  @@index([episodeId])
}

model OperatingProcess {
  id           String              @id @default(cuid())
  serviceId    String
  service      GPSSAService        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  ownerHint    String?
  sops         SopDocument[]
  systemLinks  ProcessSystemLink[]
  stageLinks   StageProcessLink[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([serviceId])
}

model SopDocument {
  id        String            @id @default(cuid())
  processId String
  process   OperatingProcess  @relation(fields: [processId], references: [id], onDelete: Cascade)
  version   String            @default("1.0")
  title     String
  status    String            @default("active") // draft | active | archived
  steps     SopStep[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([processId])
}

model SopStep {
  id            String      @id @default(cuid())
  sopId         String
  sop           SopDocument @relation(fields: [sopId], references: [id], onDelete: Cascade)
  sortOrder     Int         @default(0)
  title         String
  instruction   String?
  qaCheckpoint  Boolean     @default(false)
  checkpointNote String?
  createdAt     DateTime    @default(now())

  @@index([sopId])
}

model BackofficeSystem {
  id          String              @id @default(cuid())
  code        String              @unique
  name        String
  kind        String              @default("core") // core | crm | channel | other
  description String?
  processLinks ProcessSystemLink[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ProcessSystemLink {
  id        String           @id @default(cuid())
  processId String
  process   OperatingProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  systemId  String
  system    BackofficeSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
  role      String           @default("system-of-record") // system-of-record | intake | notify | workflow

  @@unique([processId, systemId])
  @@index([systemId])
}

model StageProcessLink {
  id        String           @id @default(cuid())
  stageId   String
  stage     JourneyStage     @relation(fields: [stageId], references: [id], onDelete: Cascade)
  processId String
  process   OperatingProcess @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@unique([stageId, processId])
  @@index([processId])
}
