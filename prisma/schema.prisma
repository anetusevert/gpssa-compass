  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([countryIso3, name])
  @@index([countryIso3])
}

model InternationalDeliveryModel {
  id                String                      @id @default(cuid())
  countryIso3       String
  name              String
  description       String?
  channelMix        String?
